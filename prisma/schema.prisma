generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  clerkId           String    @unique
  email             String
  createdAt         DateTime  @default(now())
  projects          Project[]
  wpSiteUrl         String?
  wpConsumerKey     String?
  wpConsumerSecret  String?
  wpAppPassword     String?
  plan             String    @default("free")
  credits          Int       @default(10)
  creditsUsed      Int       @default(0)
  creditsLimit     Int       @default(10)
  planExpiresAt    DateTime?
  stripeCustomerId String?
  status           String    @default("pending")
  approvedAt       DateTime?
  approvedBy       String?
  pkrPlan              String    @default("free")
  brandingLogoUrl      String?
  brandingLogoPublicId String?
  brandingPosition     String?   @default("south_east")
  brandingSize         Int?      @default(150)
  brandingOpacity      Int?      @default(70)
  shopifySiteUrl       String?
  shopifyAccessToken   String?
  makeWebhookUrl       String?
}

model Project {
  id        String           @id @default(cuid())
  userId    String
  name      String
  status    String           @default("pending")
  gender    String
  ethnicity String
  occasion  String
  prompt    String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
  uploads   Upload[]
  images    GeneratedImage[]
  reels     Reel[]
}

model Plan {
  id            String   @id @default(cuid())
  name          String   @unique
  credits       Int
  creditsLimit  Int
  priceUsd      Float
  pricePkr      Float
  stripePriceId String?
  features      String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Reel {
  id        String   @id @default(cuid())
  projectId String
  videoUrl  String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Upload {
  id        String   @id @default(cuid())
  projectId String
  imageUrl  String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model GeneratedImage {
  id        String   @id @default(cuid())
  projectId String
  imageUrl  String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
